# --- Required: Target anti-bot cookies (PerimeterX) ---
# Copy the full "cookie" header value from your browser's DevTools:
#   1. Open target.com/s?searchTerm=pokemon in Chrome
#   2. F12 → Network tab → filter "redsky" → click the product_summary request
#   3. Scroll to Request Headers → copy the entire Cookie value
# Refresh every 1-2 days when 403 errors appear again.
TARGET_COOKIES=visitorId=XXXX; _px2=XXXX; pxcts=XXXX; _tgt_session=XXXX; ...

# --- Required ---
DISCORD_BOT_TOKEN=your-bot-token-here
DISCORD_CHANNEL_ID=123456789012345678

# --- Required for Railway Redis (auto-injected by Railway when plugin is added) ---
# For local testing, run: docker run -p 6379:6379 redis
REDIS_URL=redis://localhost:6379

# --- Optional: watch specific products ---

# Comma-separated search terms (leave blank for defaults)
# Defaults: "pokemon trading card game,pokemon booster"
SEARCH_TERMS=pokemon trading card game,pokemon booster

# Comma-separated Target Item Numbers (TCINs) to monitor
# Leave blank to use keyword search (default and recommended)
# Find a TCIN in the product URL: target.com/p/-/A-XXXXXXXX
WATCH_TCINS=

# --- Optional: notifications ---

# Discord role ID to @mention on restock (leave blank to use @here)
DISCORD_ROLE_ID=

# Poll interval in seconds (default: 180 = 3 minutes)
POLL_INTERVAL_SECONDS=180

# Random jitter in seconds added/subtracted from each poll (default: 45)
POLL_JITTER_SECONDS=45
